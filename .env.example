# Copia in .env e compila i valori

# Auth JWT
JWT_SECRET=cambia-con-stringa-lunga-e-casuale

# Database (valori compatibili con docker-compose.yml)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rugbytracker
DB_USER=rugbytracker
DB_PASSWORD=rugbytracker

# Redis (valori compatibili con docker-compose.yml)
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
NODE_ENV=development
