# Copia in .env e compila i valori
# In Docker: DB_HOST=mysql, REDIS_URL=redis://redis:6379 (già configurati in docker-compose.yml)
# In locale: DB_HOST=localhost, REDIS_URL=redis://localhost:6379

# Auth JWT
JWT_SECRET=cambia-con-stringa-lunga-e-casuale

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rugbytracker
DB_USER=rugbyuser
DB_PASSWORD=rugbypass

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
NODE_ENV=development
